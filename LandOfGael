// UPDATE THE PANELS WITH REPAINTING, INSTANCED WITHIN THE INFINITE RUN LOOP
// NEED A SEPERATE METHOD TO UPDATE EACH DIFF PANEL OBJECT
public void updatePanelObjects() {

// remove the panels first
// this may need to be three seperate methods
// depending on which panel is currently set!
// actually no since we ALWAYS SET A MAIN JPANEL
this.remove(theMainPanel);
theMainPanel = new JPanel();

// THE OBJECT PANELS
// may need different methods for each diff panel object
// DO ANY CALCULATIONS
if(!setSecondPanel)
{
   aNewPanel.repaint();
}
if(setSecondPanel == true) {
	// THIS VALUE MAY ALWAYS NEED TO BE TRUE FOR THE SECONDPANEL OBJECT
   aSecondPanel.settingSecondPanel = true;
   aSecondPanel.repaint();
}

// REVALIDATE THE PANELS AND ADD THEM TO THE MAIN PANEL TO BE ADDED TO THE FRAME
aNewPanel.revalidate();
aSecondPanel.revalidate();

// Set the appropriate OBJECT PANEL to the MAIN JPanel
if(!setSecondPanel)
   theMainPanel.add(aSecondPanel);
else
   theMainPanel.add(aNewPanel);

// ADD THE MAIN JPANEL TO THIS JFRAME
this.getContentPane().add(theMainPanel);
}

// START THREAD
public void start() {
  if (runner == null) {
    runner = new Thread(this);
    runner.start();
    }
  System.out.println("STARTED NEW RUNNER THREAD");
}

// RUN 
public void run()
{
  // infinite loop
  while(true) {
    // Update all the panels and calculations
	updatePanelObjects();

	// UPDATE COUNTER THROUGH A 10,000 CYCLE
	counter++;
	if(counter >= 10000)
		counter = 0;

	// ANIMATION SLEEP
    try { Thread.sleep(10); }
	catch (InterruptedException e) { }	
  }
}

