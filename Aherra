		}
	
	// INFINITE LOOP
	// CONDITIONS AND REPAINT
	public void run() {
		while(true) { 
			// aherra biting CONDITION
			if(runner_Stall != true && controllingAherra.biting == true)
			{
				controllingAherra.repaint();
				
				// bite animation for aherra
				if(counter % 75 == 0)
					controllingAherra.biteTimer++;
				
				// make enerra jump
				//if(controllingAherra.biteTimer == 4)
					//controllingAherra.enerraJump();
			}
			// aherra jumping CONDITION
			if(runner_Stall != true && controllingAherra.jumping == true)
			{
				controllingAherra.repaint();
				
				// jump animation for aherra
				if(counter % 75 == 0)
					controllingAherra.jumpTimer++;
			}
			
			// enerra jumping CONDITION
			if(runner_Stall != true && controllingAherra.enerraJumping == true)
			{
				controllingAherra.repaint();
				
				// enerra jump animation
				if(counter % 200 == 0)
					controllingAherra.enerraJumpTimer++;
			}
			// enerra biting CONDITION
			if(runner_Stall != true && controllingAherra.enerraBiting == true)
			{
				controllingAherra.repaint();
				
				// enerra bite animation
				if(counter % 200 == 0)
					controllingAherra.enerraBiteTimer++;
			}
			
			// REFRESH the MAIN PANEL
			if(runner_Stall != true && counter % 5 == 0)
			{
				// KEYS
				if(A_Pressed)
					controllingAherra.moveLeft();
				if(S_Pressed)
					controllingAherra.moveDown();
				if(D_Pressed)
					controllingAherra.moveRight();
				if(W_Pressed)
					controllingAherra.moveUp();
				
				// make enerra bite
				if((counter % 4400 == 0 || counter % 4400 == 0) && !controllingAherra.enerraJumping)
				{
					controllingAherra.enerraBite();
					
					// if you aren't dodging or if you are biting, lose score
					// if(!controllingAherra.jumping || controllingAherra.biting)
						controllingAherra.score -= 70;
				}
					
				// make enerra jump
				if((counter % 2800 == 0 || counter % 7200 == 0) && !controllingAherra.enerraBiting)
					controllingAherra.enerraJump();
				
				//if(Space_Pressed || B_Pressed || counter % 3000 == 0)
					//controllingAherra.bite();
				
				if(counter % 500 == 0)
					controllingAherra.time++;
				controllingAherra.repaint();
			}
			
			// refresh rate
			if(counter == 100000)
				counter = 0;
			
			if(!runner_Stall)
				counter++;
			
			// ANIMATION SLEEP
			try { Thread.sleep(1); }
			catch (InterruptedException e) { }	
		}
	}
	
